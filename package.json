{
  "name": "operaxon-os",
  "version": "0.1.0",
  "description": "The open-core operating system for agentic businesses",
  "private": true,
  "workspaces": [
    "packages/*",
    "cli"
  ],
  "scripts": {
    "dev": "ts-node cli/start.ts",
    "build": "tsc -b",
    "start": "node dist/cli/start.js",
    "status": "ts-node cli/status.ts",
    "init": "ts-node cli/init.ts",
    "test": "jest",
    "docker:build": "docker build -t operaxon-os .",
    "docker:run": "docker run -p 3000:3000 operaxon-os"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "node-cron": "^3.0.3",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "inquirer": "^8.2.6",
    "commander": "^12.0.0",
    "axios": "^1.6.8",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
