# Operaxon OS — Environment Configuration
# Copy to .env and fill in your values

# Core
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Agent Identity
AGENT_NAME=my-agent
AGENT_ID=

# Channels
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SIGNAL_API_URL=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Sessions
SESSION_SECRET=change-me-in-production
SESSION_TTL_SECONDS=3600

# MCP
MCP_SERVER_URL=http://localhost:3001

# Database (optional — defaults to in-memory)
DATABASE_URL=

# Monitoring
HEALTH_CHECK_INTERVAL_MS=30000
